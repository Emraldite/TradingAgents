# Default free-first LLM setup
GOOGLE_API_KEY=
TRADINGAGENTS_LLM_PROVIDER=google
TRADINGAGENTS_DEEP_THINK_LLM=gemini-2.5-pro
TRADINGAGENTS_QUICK_THINK_LLM=gemini-2.5-flash
TRADINGAGENTS_OUTPUT_LANGUAGE=English
TRADINGAGENTS_MAX_DEBATE_ROUNDS=1
TRADINGAGENTS_MAX_RISK_ROUNDS=1
TRADINGAGENTS_CHECKPOINT_ENABLED=false

# Alpaca paper trading. Keep this paper URL until every real-money release gate
# passes and the legal account owner deliberately changes it.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Scheduler risk limits
TRADINGAGENTS_STRATEGY_VERSION=trader-v1
TRADINGAGENTS_STOP_LOSS_PCT=-0.07
TRADINGAGENTS_TAKE_PROFIT_PCT=0.12
TRADINGAGENTS_MAX_HOLD_TRADING_DAYS=10
TRADINGAGENTS_MANIPULATION_SELL_THRESHOLD=0.85
TRADINGAGENTS_LIMIT_SLIPPAGE_BPS=20
TRADINGAGENTS_SHADOW_SLIPPAGE_BPS=10
TRADINGAGENTS_MARKET_SNAPSHOT_MAX_AGE_MINUTES=5
TRADINGAGENTS_MAX_QUOTE_SPREAD_PCT=0.02
TRADINGAGENTS_BUY_POSITION_PCT=0.01
TRADINGAGENTS_OVERWEIGHT_POSITION_PCT=0.02
TRADINGAGENTS_MAX_POSITION_PCT=0.03
TRADINGAGENTS_MAX_OPEN_POSITIONS=5
TRADINGAGENTS_MIN_DAILY_VOLUME=500000
TRADINGAGENTS_DAILY_DRAWDOWN_LIMIT=0.005
TRADINGAGENTS_WEEKLY_DRAWDOWN_LIMIT=0.01
TRADINGAGENTS_TOTAL_DRAWDOWN_LIMIT=0.03

# Real-money trading is locked by default. Do not enable these until every
# documented paper-validation gate passes and the account owner is legally eligible.
TRADINGAGENTS_ALLOW_REAL_MONEY=false
TRADINGAGENTS_EXPECTED_REAL_ACCOUNT_ID=
TRADINGAGENTS_MAX_REAL_MONEY_NOTIONAL=0
TRADINGAGENTS_REAL_POSITION_PCT=0.005
TRADINGAGENTS_REAL_MAX_OPEN_POSITIONS=1
TRADINGAGENTS_REAL_MAX_EXPOSURE_PCT=0.015
TRADINGAGENTS_RELEASE_REPORT_MAX_AGE_HOURS=24
# TRADINGAGENTS_REAL_MONEY_VALIDATION_REPORT=
# TRADINGAGENTS_BACKTEST_VALIDATION_REPORT=

# AI decision scorecard
TRADINGAGENTS_SCORECARD_HORIZON_DAYS=10
TRADINGAGENTS_SCORECARD_STOP_LOSS_PCT=-0.05
TRADINGAGENTS_SCORECARD_WARMUP_POSITION_PCT=0.005
TRADINGAGENTS_SCORECARD_TIER1_POSITION_PCT=0.01
TRADINGAGENTS_SCORECARD_TIER2_POSITION_PCT=0.02
TRADINGAGENTS_SCORECARD_MIN_RESOLVED_DECISIONS=30
TRADINGAGENTS_SCORECARD_TIER2_MIN_DECISIONS=60

# Congressional and news collection
TRADINGAGENTS_CONGRESSIONAL_LOOKBACK_DAYS=45
TRADINGAGENTS_CONGRESSIONAL_MIN_CONVICTION_SCORE=6
TRADINGAGENTS_CONGRESSIONAL_CACHE_HOURS=6
TRADINGAGENTS_NEWS_ARTICLE_LIMIT=20
TRADINGAGENTS_GLOBAL_NEWS_ARTICLE_LIMIT=10
TRADINGAGENTS_GLOBAL_NEWS_LOOKBACK_DAYS=7

# Optional data/provider settings
# ALPHA_VANTAGE_API_KEY=
# TRADINGAGENTS_BENCHMARK_TICKER=SPY
# TRADINGAGENTS_LLM_BACKEND_URL=http://localhost:11434/v1
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Optional critical alerts
# DISCORD_WEBHOOK_URL=
# SLACK_WEBHOOK_URL=

# Optional storage overrides. Defaults live under ~/.tradingagents.
# TRADINGAGENTS_RESULTS_DIR=logs
# TRADINGAGENTS_CACHE_DIR=data
# TRADINGAGENTS_MEMORY_LOG_PATH=data/trading_memory.md
